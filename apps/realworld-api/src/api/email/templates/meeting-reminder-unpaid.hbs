<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Oplac swoje spotkanie</title>
  {{> styles}}
</head>
<body>
  <div class="wrapper">
    {{> header}}
    <div class="body">
      <p class="body__greeting">Czesc, {{recipientName}}! <span class="emoji">✨</span></p>
      <p class="body__text">
        Twoje spotkanie z <strong>{{wizardName}}</strong> ({{adTitle}}) odbedzie sie za <strong>{{hoursLabel}}</strong>.
      </p>
      <div class="highlight">
        <strong>Spotkanie nie zostalo jeszcze oplacone.</strong><br />
        Oplac teraz, aby moc dolaczyc do wideorozmowy. Oplata: {{priceFormatted}} - czas: {{durationMinutes}} min.
      </div>
      <div class="btn-wrapper">
        <a href="{{paymentUrl}}" class="btn">Oplac spotkanie</a>
      </div>
      <p class="body__text">
        {{paymentHint}}
      </p>
    </div>
    {{> footer}}
  </div>
</body>
</html>
