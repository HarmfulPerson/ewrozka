<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wiadomość z formularza kontaktowego</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      color: #1a1a2e;
      padding: 24px;
      background: #f5f5f7;
    }
    .wrapper {
      max-width: 560px;
      margin: 0 auto;
      background: #fff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .header {
      background: linear-gradient(135deg, #6d28d9 0%, #a855f7 100%);
      padding: 20px 24px;
      color: #fff;
      font-weight: 700;
      font-size: 1.1rem;
    }
    .body {
      padding: 24px;
    }
    .field {
      margin-bottom: 16px;
    }
    .field__label {
      font-size: 0.75rem;
      font-weight: 600;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 4px;
    }
    .field__value {
      font-size: 0.9375rem;
      color: #1a1a2e;
      line-height: 1.5;
    }
    .message-box {
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 16px;
      white-space: pre-wrap;
      word-break: break-word;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header" style="color:#ffffff !important;">eWróżka – nowa wiadomość z formularza kontaktowego</div>
    <div class="body">
      <div class="field">
        <div class="field__label">Od</div>
        <div class="field__value">{{name}} &lt;{{email}}&gt;</div>
      </div>
      {{#if subject}}
      <div class="field">
        <div class="field__label">Temat</div>
        <div class="field__value">{{subject}}</div>
      </div>
      {{/if}}
      <div class="field">
        <div class="field__label">Wiadomość</div>
        <div class="message-box">{{message}}</div>
      </div>
    </div>
  </div>
</body>
</html>
