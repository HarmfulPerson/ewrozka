# ── Skopiuj do: /opt/ewrozka/.env.staging na serwerze ─────────────────────────

NODE_ENV=staging

APP_NAME="eWróżka (Staging)"
APP_URL=https://staging.ewrozka.online
APP_PORT=8001
APP_DEBUG=true
APP_FALLBACK_LANGUAGE=pl
APP_LOG_LEVEL=debug
APP_LOG_SERVICE=console
APP_CORS_ORIGIN=https://staging.ewrozka.online
API_PREFIX=api
API_DOCS_ENABLED=true

DATABASE_TYPE=postgres
DATABASE_HOST=db-staging
DATABASE_PORT=5432
DATABASE_USERNAME=ewrozka_staging
DATABASE_PASSWORD=ZMIEN_NA_INNE_HASLO
DATABASE_NAME=ewrozka_staging
DATABASE_SCHEMA=public
DATABASE_LOGGING=true
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=20
DATABASE_SSL_ENABLED=false

# JWT
AUTH_JWT_SECRET=INNY_KLUCZ_NIZ_PROD
AUTH_JWT_TOKEN_EXPIRES_IN=7d

# Stripe (klucze TEST)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Daily.co (można użyć tych samych)
DAILY_API_KEY=TWOJ_KLUCZ_DAILY
DAILY_DOMAIN=ewrozka.daily.co

PLATFORM_FEE_PERCENTAGE=20
PAYMENT_CURRENCY=PLN

FEATURED_PRICE_GROSZE=2000
FEATURED_DURATION_HOURS=6
FEATURED_SLOTS=6
FEATURED_ROTATION_SECONDS=90

WIZARD_VIDEO_MAX_DURATION_SECONDS=30
WIZARD_VIDEO_MAX_SIZE_MB=50

# Email (Mailtrap na staging)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=TWOJ_MAILTRAP_USER
MAIL_PASS=TWOJ_MAILTRAP_PASS
MAIL_FROM=staging@ewrozka.online
