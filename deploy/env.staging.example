# ── Skopiuj do: /opt/ewrozka/.env.staging na serwerze ─────────────────────────
# NIGDY nie commituj tego pliku z prawdziwymi wartościami do git!

NODE_ENV=staging

# Aplikacja
APP_NAME="eWróżka (Staging)"
APP_URL=https://api-staging.ewrozka.online
APP_PORT=8001
APP_DEBUG=false
APP_FALLBACK_LANGUAGE=pl
APP_LOG_LEVEL=debug
APP_LOG_SERVICE=console
APP_CORS_ORIGIN=https://staging.ewrozka.online
API_PREFIX=api
API_DOCS_ENABLED=true

# Baza danych (host = nazwa serwisu docker: "db-staging")
DATABASE_TYPE=postgres
DATABASE_HOST=db-staging
DATABASE_PORT=5432
DATABASE_USERNAME=ewrozka_staging
DATABASE_PASSWORD=ZMIEN_NA_INNE_HASLO
DATABASE_NAME=ewrozka_staging
DATABASE_SCHEMA=public
DATABASE_LOGGING=false
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=20
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false

# JWT - wygeneruj: openssl rand -hex 64
AUTH_JWT_SECRET=INNY_KLUCZ_NIZ_PROD
AUTH_JWT_TOKEN_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=TWOJ_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX_TWOJ_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=https://api-staging.ewrozka.online/auth/google/callback

# Stripe (klucze TEST)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET – wygeneruj na serwerze po pierwszym deploymencie:
# stripe listen --forward-to https://api-staging.ewrozka.online/api/stripe/webhook
# lub w Stripe Dashboard → Webhooks → Add endpoint: https://api-staging.ewrozka.online/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_WYGENERUJ_W_STRIPE_DASHBOARD

# Stripe Connect
FRONTEND_URL=https://staging.ewrozka.online
STRIPE_CONNECT_RETURN_URL=https://staging.ewrozka.online/panel/portfel
STRIPE_CONNECT_REFRESH_URL=https://staging.ewrozka.online/panel/portfel

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=https://api-staging.ewrozka.online/api
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Daily.co
DAILY_API_KEY=TWOJ_KLUCZ_DAILY
DAILY_DOMAIN=ewrozka.daily.co

# Platności
PLATFORM_FEE_PERCENTAGE=20
PAYMENT_CURRENCY=PLN

# Wyróżnienie wróżek
FEATURED_PRICE_GROSZE=2000
FEATURED_DURATION_HOURS=6
FEATURED_SLOTS=6
FEATURED_ROTATION_SECONDS=90

# Wideo wróżek
WIZARD_VIDEO_MAX_DURATION_SECONDS=30
WIZARD_VIDEO_MAX_SIZE_MB=50

# Email (Mailtrap na staging – darmowe konto na mailtrap.io)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=TWOJ_MAILTRAP_USER
MAIL_PASS=TWOJ_MAILTRAP_PASS
MAIL_FROM=staging@ewrozka.online
