# ── Skopiuj do: /opt/ewrozka/.env.production na serwerze ──────────────────────
# NIGDY nie commituj tego pliku z prawdziwymi wartościami do git!

NODE_ENV=production

APP_NAME="eWróżka"
APP_URL=https://ewrozka.online
APP_PORT=8001
APP_DEBUG=false
APP_FALLBACK_LANGUAGE=pl
APP_LOG_LEVEL=warn
APP_LOG_SERVICE=console
APP_CORS_ORIGIN=https://ewrozka.online,https://www.ewrozka.online
API_PREFIX=api
API_DOCS_ENABLED=false

# Baza danych (host = nazwa serwisu docker: "db")
DATABASE_TYPE=postgres
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USERNAME=ewrozka_prod
DATABASE_PASSWORD=ZMIEN_NA_SILNE_HASLO
DATABASE_NAME=ewrozka_prod
DATABASE_SCHEMA=public
DATABASE_LOGGING=false
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=50
DATABASE_SSL_ENABLED=false

# JWT - wygeneruj: openssl rand -hex 64
AUTH_JWT_SECRET=ZMIEN_NA_LOSOWY_KLUCZ_64_ZNAKI
AUTH_JWT_TOKEN_EXPIRES_IN=7d

# Stripe (klucze LIVE)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Daily.co
DAILY_API_KEY=TWOJ_KLUCZ_DAILY
DAILY_DOMAIN=ewrozka.daily.co

# Platności
PLATFORM_FEE_PERCENTAGE=20
PAYMENT_CURRENCY=PLN

# Wyróżnienie wróżek
FEATURED_PRICE_GROSZE=2000
FEATURED_DURATION_HOURS=6
FEATURED_SLOTS=6
FEATURED_ROTATION_SECONDS=90

# Wideo wróżek
WIZARD_VIDEO_MAX_DURATION_SECONDS=30
WIZARD_VIDEO_MAX_SIZE_MB=50

# Email (SMTP)
MAIL_HOST=smtp.twojdostawca.pl
MAIL_PORT=587
MAIL_USER=noreply@ewrozka.online
MAIL_PASS=HASLO_SMTP
MAIL_FROM=noreply@ewrozka.online
